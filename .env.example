# puzzpool environment configuration
# Copy to .env and adjust for your deployment.
# The server reads these via process.env — no .env auto-loading;
# use `export $(cat .env | xargs)` or set them in your systemd unit.

# Port the Express server binds to (127.0.0.1 only, behind Nginx)
PORT=8888

# SQLite database file path (relative to working directory, or absolute)
DB_PATH=pool.db

# Minutes a chunk should take to scan (used to size chunks per worker's hashrate)
TARGET_MINUTES=5

# Minutes before an unfinished chunk is reclaimed and reissued
TIMEOUT_MINUTES=15

# Minutes a worker stays green (active) after its last heartbeat/work call.
# Accepts fractional values (e.g. 0.333 ≈ 20 seconds).
# Automatically capped at half of TIMEOUT_MINUTES so the gray phase is always visible.
ACTIVE_MINUTES=3

# Maximum number of sectors the keyspace is divided into (must be a positive integer).
# More sectors = finer spatial spread but slower ORDER BY RANDOM() sector selection.
# Benchmark /api/v1/work under load before raising significantly above the default.
TARGET_SECTORS=65536

# Deployment stage — shown in dashboard and used to tint the favicon.
# Use PROD for production, TEST for the test instance.
STAGE=PROD

# Admin API token — if set, all /api/v1/admin/* routes require
# the header:  X-Admin-Token: <value>
# Leave blank (or unset) to disable auth (suitable for localhost-only deployments
# where Nginx restricts admin routes by IP).
ADMIN_TOKEN=

# Keyspace definitions — any number of KEYSPACE_<NAME>=<start_hex>:<end_hex> entries.
# NAME (underscores replaced with spaces) becomes the puzzle name in the dashboard.
# On startup, missing puzzles are seeded automatically (inactive by default).
# The first puzzle in the DB is activated if none is currently active.
#
# Example:
# KEYSPACE_PUZZLE_71=0x0400000000000000000:0x07fffffffffffffffff
# KEYSPACE_ALL_BTC=0x1:0xfffffffffffffffffffffffffffffffebaaedce6af48a03bbfd25e8cd0364141
